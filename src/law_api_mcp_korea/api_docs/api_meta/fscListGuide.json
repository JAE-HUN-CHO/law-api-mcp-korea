{
  "request_params": [
    {
      "name": "OC",
      "type_info": "string, 필수",
      "required": true,
      "description": "사용자 이메일 ID"
    },
    {
      "name": "target",
      "type_info": "string(필수) (금융위원회 : fsc)",
      "required": true,
      "description": "서비스 대상(위원회별 target 코드)"
    },
    {
      "name": "type",
      "type_info": "char, 필수",
      "required": true,
      "description": "출력 형태 : HTML/XML/JSON"
    },
    {
      "name": "search",
      "type_info": "int",
      "required": false,
      "description": "검색범위(기본: 1 제목, 2 본문검색)"
    },
    {
      "name": "query",
      "type_info": "string",
      "required": false,
      "description": "검색어"
    },
    {
      "name": "display",
      "type_info": "int",
      "required": false,
      "description": "검색된 결과 개수(default=20, max=100)"
    },
    {
      "name": "page",
      "type_info": "int",
      "required": false,
      "description": "검색 결과 페이지(default=1)"
    },
    {
      "name": "gana",
      "type_info": "string",
      "required": false,
      "description": "사전식 검색(ga,na,da…)"
    },
    {
      "name": "sort",
      "type_info": "string",
      "required": false,
      "description": "정렬옵션(lasc/ldes/dasc/ddes/nasc/ndes 등)"
    },
    {
      "name": "popYn",
      "type_info": "string",
      "required": false,
      "description": "상세화면 팝업 여부"
    }
  ],
  "response_fields": [
    {
      "name": "target",
      "type_info": "string",
      "description": "검색서비스 대상"
    },
    {
      "name": "키워드",
      "type_info": "string",
      "description": "검색 단어"
    },
    {
      "name": "section",
      "type_info": "string",
      "description": "검색범위"
    },
    {
      "name": "totalCnt",
      "type_info": "int",
      "description": "검색 건수"
    },
    {
      "name": "page",
      "type_info": "int",
      "description": "현재 페이지번호"
    },
    {
      "name": "기관명",
      "type_info": "string",
      "description": "위원회명"
    },
    {
      "name": "id",
      "type_info": "int",
      "description": "검색 결과 순번"
    },
    {
      "name": "결정문일련번호",
      "type_info": "int",
      "description": "결정문 일련번호"
    },
    {
      "name": "제목",
      "type_info": "string",
      "description": "제목"
    },
    {
      "name": "사건번호",
      "type_info": "string",
      "description": "사건번호"
    },
    {
      "name": "등록일",
      "type_info": "string",
      "description": "등록일"
    },
    {
      "name": "결정문상세링크",
      "type_info": "string",
      "description": "결정문 상세링크"
    }
  ],
  "notes": [
    "노동위원회(nlrc) 대표 가이드 구조를 기준으로 동일 계열 위원회 API를 정규화했습니다."
  ],
  "sample_requests": [
