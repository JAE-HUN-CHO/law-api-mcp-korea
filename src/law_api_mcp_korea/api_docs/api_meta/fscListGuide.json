    "{\n  \"data\": [\n    {\n      \"target\": \"예시값\",\n      \"키워드\": \"사건\",\n      \"section\": \"예시값\",\n      \"totalCnt\": 20,\n      \"제목\": \"예시 사건\",\n      \"결정문상세링크\": \"https://www.law.go.kr/...\"\n    }\n  ]\n}"
