    },
    {
      "name": "rrClsCd",
      "type_info": "string",
      "required": false,
      "description": "법령 제개정 종류 (300201-제정 / 300202-일부개정 / 300203-전부개정 300204-폐지 / 300205-폐지제정 / 300206-일괄개정 300207-일괄폐지 / 300208-타법개정 / 300209-타법폐지 300214-기타)"
    },
    {
      "name": "ordinFd",
      "type_info": "int",
      "required": false,
