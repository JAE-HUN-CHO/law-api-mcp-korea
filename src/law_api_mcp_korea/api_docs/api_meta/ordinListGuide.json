    },
    {
      "name": "lsChapNo",
      "type_info": "string",
      "required": false,
      "description": "법령분야별 검색(법령분야코드제공) (ex. 제1편 검색 lsChapNo=01000000 / 제1편2장,제1편2장1절 lsChapNo=01020000,01020100)"
    },
    {
      "name": "gana",
      "type_info": "string",
