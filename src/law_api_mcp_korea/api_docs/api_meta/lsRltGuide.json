{
  "request_params": [
    {
      "name": "OC",
      "type_info": "string, 필수",
      "required": true,
      "description": "사용자 이메일 ID"
    },
    {
      "name": "target",
      "type_info": "string : lsRlt(필수)",
      "required": true,
      "description": "서비스 대상"
    },
    {
      "name": "type",
      "type_info": "char, 필수",
      "required": true,
      "description": "출력 형태 : XML/JSON"
    },
    {
      "name": "query",
      "type_info": "string",
      "required": false,
      "description": "검색 질의 또는 대상 식별값"
    },
    {
      "name": "display",
      "type_info": "int",
      "required": false,
      "description": "검색된 결과 개수(default=20, max=100)"
    },
    {
      "name": "page",
      "type_info": "int",
      "required": false,
      "description": "검색 결과 페이지(default=1)"
    }
  ],
  "response_fields": [
    {
      "name": "target",
      "type_info": "string",
      "description": "검색서비스 대상"
    },
    {
      "name": "키워드",
      "type_info": "string",
      "description": "검색 질의"
    },
    {
      "name": "검색결과개수",
      "type_info": "int",
      "description": "검색 건수"
    },
    {
      "name": "page",
      "type_info": "int",
      "description": "현재 페이지번호"
    },
    {
      "name": "id",
      "type_info": "string/int",
      "description": "결과 식별자"
    },
    {
      "name": "명칭",
      "type_info": "string",
      "description": "용어/조문/법령명"
    },
    {
      "name": "설명",
      "type_info": "string",
      "description": "설명 또는 관계 정보"
    },
    {
      "name": "상세링크",
      "type_info": "string",
      "description": "관계/상세 정보 링크"
    }
  ],
  "notes": [
    "법령정보지식베이스 API군은 target별 관계 유형만 달라지고 기본 요청/응답 구조는 유사합니다."
  ],
  "sample_requests": [
    "https://www.law.go.kr/DRF/lawSearch.do?target=lsRlt&OC=test&type=XML&query=자동차&display=20&page=1",
    "https://www.law.go.kr/DRF/lawSearch.do?target=lsRlt&OC=test&type=JSON&query=자동차&display=20&page=1",
    "<response>\n  <item>\n    <field name=\"target\">예시값</field>\n    <field name=\"키워드\">자동차</field>\n    <field name=\"검색결과개수\">20</field>\n    <field name=\"page\">1</field>\n    <field name=\"명칭\">자동차관리법</field>\n    <field name=\"상세링크\">https://www.law.go.kr/...</field>\n  </item>\n</response>",
    "{\n  \"data\": [\n    {\n      \"target\": \"예시값\",\n      \"키워드\": \"자동차\",\n      \"검색결과개수\": 20,\n      \"page\": 1,\n      \"명칭\": \"자동차관리법\",\n      \"상세링크\": \"https://www.law.go.kr/...\"\n    }\n  ]\n}"
  ],
  "sample_responses": []
}
